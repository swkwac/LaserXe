# Python backend API (gdy frontend wywołuje backend z innego hosta/portu)
PUBLIC_API_URL=http://localhost:8000
# Troubleshooting (np. .\backend\start-api.ps1 -Port 8001 gdy port 8000 jest zajęty przez inny proces):
# PUBLIC_API_URL=http://localhost:8001

# Opcjonalnie (poza MVP)
OPENROUTER_API_KEY=###

# Auth (cookie session)
AUTH_SECRET_KEY=change-me
AUTH_COOKIE_NAME=laserxe_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_SECONDS=3600

# XDA / XD-OEM linear controller (read by Python backend process — export or put in backend/.env)
# XDA_SKIP_ENCODER_INDEX=1
# XDA_USE_CRLF=1
# XDA_INDEX_DIR=0
# XDA_INDEX_SETTLE_S=3.5
# XDA_INFO_MODE=0
# XDA_SEND_LOAD_ON_CONNECT=1
# XDA_LOG_IO=1
# XDA_USE_AXIS_PREFIX=0
# XDA_ENBL_VALUE=3
# XDA_JOG_USE_STEP=1
# XDA_JOG_OPEN_LOOP=1
# XDA_OPEN_LOOP_PULSE_S=0.25
# XDA_JOG_STEP_UNITS=800
# XDA_TEST_SSPD=5000
# XDA_TEST_STEP_UNITS=128200
# XDA_TEST_INCLUDE_INDX=0
# XDA_SCAN_JOG_MAGNITUDE=10000
# (legacy only: omit to use SCAN=±1 per Xeryon startScan API; speed comes from SSPD / max_speed_units)
# Backend sends INFO=0 and ENBL=1 once per new XDA USB session.
